$env:APP_ENV = "production"
$env:SESSION_SECRET_KEY = "replace-with-long-random-secret"
$env:SESSION_COOKIE_SECURE = "1"

# Keep production data outside the application code directory.
$env:DATABASE_PATH = "C:\SkladData\sklad_requests.db"

# Only needed on the first production start when there is no active admin.
$env:INITIAL_ADMIN_LOGIN = "admin"
$env:INITIAL_ADMIN_PASSWORD = "replace-with-temporary-strong-password"

# Leave false in production to avoid demo users with known passwords.
$env:SEED_DEMO_USERS = "false"
