APP_ENV=production
SESSION_SECRET_KEY=replace-with-long-random-secret
SESSION_COOKIE_SECURE=1

# Keep production data outside the application code directory.
DATABASE_PATH=/var/lib/sklad/sklad_requests.db

# Only needed on the first production start when there is no active admin.
INITIAL_ADMIN_LOGIN=admin
INITIAL_ADMIN_PASSWORD=replace-with-temporary-strong-password

# Leave false in production to avoid demo users with known passwords.
SEED_DEMO_USERS=false
